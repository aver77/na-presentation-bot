{
    "compilerOptions": {
        "rootDir": "src",
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "types": ["node"]
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist", "build"]
}
